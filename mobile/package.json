{
  "name": "app-mob",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "build:android:apk": "eas build -p android --profile preview",
    "build:android:local-debug": "expo prebuild --platform android --clean && cd android && gradlew.bat assembleDebug",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.12",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.1",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
