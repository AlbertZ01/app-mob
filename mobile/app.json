{
  "expo": {
    "name": "MoodMix",
    "slug": "app-mob",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "appmob",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.albertz01.appmob",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101820"
      }
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101820"
    }
  }
}
