{
  "expo": {
    "name": "kazp",
    "slug": "app-mob",
    "version": "0.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "description": "kazp analyzes the group's Spotify taste, signs users in and keeps the party session updated live.",
    "icon": "./assets/icon.png",
    "newArchEnabled": false,
    "userInterfaceStyle": "dark",
    "scheme": "appmob",
    "updates": {
      "url": "https://u.expo.dev/ac34996a-8275-461a-a05d-8daf9fc9f2dd",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.albertz01.appmob",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07110D"
      }
    },
    "ios": {
      "bundleIdentifier": "com.albertz01.appmob",
      "buildNumber": "1",
      "supportsTablet": false
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07110D"
    },
    "extra": {
      "eas": {
        "projectId": "ac34996a-8275-461a-a05d-8daf9fc9f2dd"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ]
  }
}
